# Скопируйте в корень репозитория как Caddyfile на сервере (или подключите volume).
# Замените astrogen.ru на ваш боевой домен; для www настройте редирект или второй блок.
# До деплоя: DNS A/AAAA на этот сервер, порты 80/443 открыты для ACME.
# Корень / — лендинг FastAPI (static/); SPA — только на /order, /dashboard, /reports, /auth/callback, /cabinet/orders.
# reverse_proxy передаёт X-Forwarded-Proto; на бэкенде задайте FORWARDED_ALLOW_IPS (см. docker-compose.prod.yml, docs/DEPLOY_URLS.md).

astrogen.ru {
    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security max-age=31536000;
    }

    handle_path /api/* {
        reverse_proxy fastapi:8000
    }

    handle_path /admin/* {
        reverse_proxy fastapi:8000
    }

    handle /health {
        reverse_proxy fastapi:8000
    }

    handle /health/ready {
        reverse_proxy fastapi:8000
    }

    handle /assets/* {
        root * /srv/frontend
        file_server
    }

    handle /favicon.ico {
        root * /srv/frontend
        file_server
    }

    @spa_cabinet_orders path /cabinet/orders /cabinet/orders/*
    handle @spa_cabinet_orders {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    @spa_order path /order /order/*
    handle @spa_order {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    @spa_dashboard path /dashboard /dashboard/*
    handle @spa_dashboard {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    @spa_reports path /reports /reports/*
    handle @spa_reports {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    @spa_oauth_cb path /auth/callback /auth/callback/*
    handle @spa_oauth_cb {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    handle {
        reverse_proxy fastapi:8000
    }
}
