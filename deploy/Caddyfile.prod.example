# Скопируйте в корень репозитория как Caddyfile на сервере (или подключите volume).
# Замените astrogen.ru на ваш боевой домен; для www настройте редирект или второй блок.
# До деплоя: DNS A/AAAA на этот сервер, порты 80/443 открыты для ACME.

astrogen.ru {
    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security max-age=31536000;
    }

    handle / {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    handle_path /api/* {
        reverse_proxy fastapi:8000
    }

    handle_path /admin/* {
        reverse_proxy fastapi:8000
    }

    handle /health {
        reverse_proxy fastapi:8000
    }

    handle /health/ready {
        reverse_proxy fastapi:8000
    }
}
