# База API: в dev полный URL к FastAPI; в prod относительный путь (тот же origin, Caddy проксирует /api)
VITE_API_URL=http://localhost:8000/api/v1

# Origin фронта (для ссылок OAuth в dev, если отличается от Vite)
VITE_APP_ORIGIN=http://localhost:5173

# HTML-лендинг (FastAPI) — ссылки «на сайт» и блок тарифов в dev
# VITE_LANDING_ORIGIN=http://127.0.0.1:8000

# User-Agent для Nominatim (политика использования)
VITE_GEOCODER_USER_AGENT=AstroGen/1.0 (contact@example.com)

# Ссылка на Mini App в Telegram (кнопка «Войти через Telegram» на лендинге в браузере)
# VITE_TELEGRAM_MINIAPP_URL=https://t.me/YourBot/yourapp
