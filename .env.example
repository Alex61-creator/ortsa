# Application
PROJECT_NAME="AstroGen"
ENVIRONMENT=development
DEBUG=false
API_V1_STR="/api/v1"
SECRET_KEY=your-secret-key-here-change-in-production
BACKEND_CORS_ORIGINS=["https://yourdomain.com", "https://t.me", "https://*.telegram.org"]
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# За Caddy/nginx: Uvicorn доверяет X-Forwarded-Proto только от этих сетей (OAuth redirect_uri = https://).
# В docker-compose уже задано по умолчанию; при нестандартной сети — FORWARDED_ALLOW_IPS=* (только если API не торчит в интернет).
# FORWARDED_ALLOW_IPS=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16,127.0.0.1

# Database
POSTGRES_SERVER=postgres
POSTGRES_USER=astro_user
POSTGRES_PASSWORD=astro_pass
POSTGRES_DB=astro_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:5432/${POSTGRES_DB}
# Пул соединений SQLAlchemy (сумма с Celery < max_connections PostgreSQL)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# Storage (регулярный бэкап каталога STORAGE_DIR и политика retention — вне приложения)
STORAGE_DIR=/app/storage
STORAGE_RETENTION_DAYS=90

# OAuth
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY_PATH=/app/apple_key.p8

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://yourdomain.com/payment/success
# Публичный URL фронтенда (SPA): письма «отчёт готов». OAuth callback (Google/Яндекс/Apple): схема и host redirect_uri = из этого URL (на проде обязательно https://). Если не задан — используется YOOKASSA_RETURN_URL.
PUBLIC_APP_URL=https://yourdomain.com
# Канонический URL сайта для SEO (canonical, sitemap, OG). Если не задан — как PUBLIC_APP_URL.
# SITE_URL=https://yourdomain.com
# Верификация в Search Console / Вебмастере (опционально, только content токена)
# GOOGLE_SITE_VERIFICATION=
# YANDEX_VERIFICATION=
# BING_SITE_VERIFICATION=
# Уведомления: IP-лист ЮKassa + сверка через API (рекомендация документации). Для локальных тестов можно false.
YOOKASSA_WEBHOOK_VERIFY_IP=true
YOOKASSA_WEBHOOK_VERIFY_API=true

# Telegram Mini App: макс. возраст initData (сек.), см. core.telegram.org/bots/webapps
TWA_AUTH_MAX_AGE_SECONDS=86400

# Опционально: мониторинг ошибок (Sentry)
# SENTRY_DSN=

# DeepSeek
DEEPSEEK_API_KEY=sk-...
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_MAX_TOKENS_FREE=2048
LLM_MAX_TOKENS_FULL=4096
LLM_MAX_TOKENS_PRO=6144
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
# Таймаут HTTP к api.deepseek.com (сек.)
LLM_HTTP_TIMEOUT_SECONDS=300

# SMTP (рекомендуется [Unisender](https://www.unisender.com/): транзакционная почта через Unisender Go — см. https://godocs.unisender.ru/smtp-api)
# Хост: smtp.go1.unisender.ru или smtp.go2.unisender.ru (зависит от дата-центра аккаунта go1/go2). Порт 587 + TLS (STARTTLS).
# Логин: user_id или project_id; пароль: API-ключ из кабинета (https://go2.unisender.ru/ru/settings/security/api — для Go).
SMTP_HOST=smtp.go1.unisender.ru
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_TLS=true

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=securepassword
ADMIN_EMAIL=admin@example.com
# Админ-SPA (отдельный поддомен): OAuth redirect и CORS
# ADMIN_APP_ORIGIN=https://admin.example.com
# Через запятую: email Google и числовые id Telegram — при входе выставляется is_admin=true
# ADMIN_GOOGLE_EMAILS=you@gmail.com
# ADMIN_TELEGRAM_USER_IDS=123456789

# Readiness /health/ready: проверка Celery (ping воркеров + длина очереди redis «celery»)
HEALTH_CHECK_CELERY=false
# CELERY_QUEUE_ALERT_LENGTH=50
# CELERY_QUEUE_FAIL_READINESS=false

# Rate Limit
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_ORDERS_PER_MINUTE=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json