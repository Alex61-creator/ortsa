# Application
PROJECT_NAME="AstroGen"
ENVIRONMENT=development
DEBUG=false
API_V1_STR="/api/v1"
SECRET_KEY=your-secret-key-here-change-in-production
BACKEND_CORS_ORIGINS=["https://yourdomain.com", "https://t.me", "https://*.telegram.org"]
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database
POSTGRES_SERVER=postgres
POSTGRES_USER=astro_user
POSTGRES_PASSWORD=astro_pass
POSTGRES_DB=astro_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:5432/${POSTGRES_DB}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# Storage (регулярный бэкап каталога STORAGE_DIR и политика retention — вне приложения)
STORAGE_DIR=/app/storage
STORAGE_RETENTION_DAYS=90

# OAuth
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY_PATH=/app/apple_key.p8

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://yourdomain.com/payment/success
# Публичный URL фронтенда (SPA): письма «отчёт готов», OAuth redirect. Если не задан — используется YOOKASSA_RETURN_URL.
PUBLIC_APP_URL=https://yourdomain.com
# Канонический URL сайта для SEO (canonical, sitemap, OG). Если не задан — как PUBLIC_APP_URL.
# SITE_URL=https://yourdomain.com
# Верификация в Search Console / Вебмастере (опционально, только content токена)
# GOOGLE_SITE_VERIFICATION=
# YANDEX_VERIFICATION=
# BING_SITE_VERIFICATION=
# Уведомления: IP-лист ЮKassa + сверка через API (рекомендация документации). Для локальных тестов можно false.
YOOKASSA_WEBHOOK_VERIFY_IP=true
YOOKASSA_WEBHOOK_VERIFY_API=true

# Telegram Mini App: макс. возраст initData (сек.), см. core.telegram.org/bots/webapps
TWA_AUTH_MAX_AGE_SECONDS=86400

# Опционально: мониторинг ошибок (Sentry)
# SENTRY_DSN=

# DeepSeek
DEEPSEEK_API_KEY=sk-...
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_MAX_TOKENS_FREE=2048
LLM_MAX_TOKENS_FULL=4096
LLM_MAX_TOKENS_PRO=6144
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=app-password
SMTP_FROM=noreply@yourdomain.com
SMTP_TLS=true

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=securepassword
ADMIN_EMAIL=admin@example.com

# Rate Limit
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_ORDERS_PER_MINUTE=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json