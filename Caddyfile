# Прод: TLS через ACME. Черновик с примером домена: deploy/Caddyfile.prod.example (скопируйте и переименуйте блок домена).
# HTML с FastAPI уже получает CSP из SecurityHeadersMiddleware (см. app/middleware/security_headers.py).
# Корень / и маркетинг — FastAPI + static/; React SPA только на путях приложения (см. handle ниже).
#
# reverse_proxy передаёт X-Forwarded-Proto (https). Uvicorn учитывает его только если IP прокси в FORWARDED_ALLOW_IPS
# (в docker-compose задано по умолчанию); иначе redirect_uri в OAuth остаётся http:// — в консолях Google/Яндекс указывайте https://…
#
# www → основной хост (замените yourdomain.com на боевой домен; DNS: A/AAAA для @ и для www).
# Если TLS терминирует Cloudflare: аналог в Rules → Redirect Rules (301, www → apex).
www.yourdomain.com {
    redir https://yourdomain.com{uri} permanent
}

yourdomain.com {
    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security max-age=31536000;
    }

    handle /api/* {
        reverse_proxy fastapi:8000
    }

    handle /admin/* {
        reverse_proxy fastapi:8000
    }

    handle /health {
        reverse_proxy fastapi:8000
    }

    handle /health/ready {
        reverse_proxy fastapi:8000
    }

    handle /assets/* {
        root * /srv/frontend
        file_server
    }

    handle /favicon.ico {
        root * /srv/frontend
        file_server
    }

    @spa_cabinet_orders path /cabinet/orders /cabinet/orders/*
    handle @spa_cabinet_orders {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    @spa_order path /order /order/*
    handle @spa_order {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    @spa_dashboard path /dashboard /dashboard/*
    handle @spa_dashboard {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    @spa_reports path /reports /reports/*
    handle @spa_reports {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    @spa_oauth_cb path /auth/callback /auth/callback/*
    handle @spa_oauth_cb {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    handle {
        reverse_proxy fastapi:8000
    }
}

# Локальная разработка в Docker: без ACME/TLS, весь трафик на FastAPI (лендинг /static и /api).
# За внешним reverse proxy задайте доверие к X-Forwarded-For (см. README: вебхуки ЮKassa).
http://localhost, http://127.0.0.1 {
    encode gzip
    reverse_proxy fastapi:8000
}
